# =============================================
# EveryUp Log Agent configuration
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================

# EveryUp server URL (required)
LOG_AGENT_ENDPOINT=http://your-everyup-server:3001

# Service API key (required), copied from EveryUp Logs > Integration
LOG_AGENT_API_KEY=everyup_your_api_key_here

# Log file path to collect (glob supported)
LOG_AGENT_FILE=/var/log/app/*.log

# Agent log level (debug / info / warn / error)
LOG_AGENT_LEVEL=info

# Host log directory mounted into the container as /var/log/app
LOG_AGENT_PATH=/path/to/your/app/logs
