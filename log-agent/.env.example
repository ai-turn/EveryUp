# =============================================
# EveryUp Log Agent 설정
# 이 파일을 .env로 복사하여 값을 채우세요:
#   cp .env.example .env
# =============================================

# EveryUp 서버 URL (필수)
LOG_AGENT_ENDPOINT=http://your-everyup-server:3001

# 서비스 API Key (필수) — EveryUp 대시보드 > 서비스 > Integration 탭에서 복사
LOG_AGENT_API_KEY=la_your_api_key_here

# 수집할 로그 파일 경로 (glob 지원)
LOG_AGENT_FILE=/var/log/app/*.log

# 로그 레벨 (debug / info / warn / error)
LOG_AGENT_LEVEL=info

# 호스트의 로그 디렉토리 경로 (컨테이너 내부 /var/log/app 로 마운트됨)
LOG_AGENT_PATH=/path/to/your/app/logs

# =============================================
# 테스트 콘솔 UI (선택)
# =============================================

# 테스트 콘솔 활성화 여부
LOG_AGENT_WEB_CONSOLE=true

# 테스트 콘솔 포트
LOG_AGENT_WEB_CONSOLE_PORT=8080
