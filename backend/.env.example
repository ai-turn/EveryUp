# EveryUp Backend — Environment Variables
# Copy to .env and adjust values:
#   cp .env.example .env
#
# Priority: env vars > .env file > config.json > defaults

# -----------------------------------------------------------------
# Server
# -----------------------------------------------------------------

# Run mode: development | production
# production mode enforces: no wildcard CORS, strong admin password
MT_SERVER_MODE=development

# Bind host and port (defaults: 0.0.0.0, 3001)
# MT_SERVER_HOST=0.0.0.0
# MT_SERVER_PORT=3001

# Allowed CORS origins (comma-separated)
# Required when frontend runs on a different port (local dev: Vite on :5173)
# Leave unset for same-origin / reverse-proxy / Docker setups
MT_SERVER_ALLOWORIGINS=http://localhost:5173

# -----------------------------------------------------------------
# Admin account
# -----------------------------------------------------------------

# If set, creates or resets the admin login account on every startup.
# Remove after first run if you don't want automatic password resets.
MT_ADMIN_USERNAME=admin
MT_ADMIN_PASSWORD=changeme

# -----------------------------------------------------------------
# Database
# -----------------------------------------------------------------

# SQLite file path (relative to working directory)
# MT_DATABASE_PATH=./data/monitoring.db

# -----------------------------------------------------------------
# System monitoring
# -----------------------------------------------------------------

# Metric collection interval in seconds (default: 5)
# MT_SYSTEM_COLLECTINTERVAL=5

# Metric store interval in seconds (default: 60)
# MT_SYSTEM_STOREINTERVAL=60

# -----------------------------------------------------------------
# Timezone (used by Docker / process)
# -----------------------------------------------------------------
TZ=Asia/Seoul
