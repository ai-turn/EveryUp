# Copy this file to .env and fill in the values
# cp .env.example .env

# [Optional] Timezone (default: UTC)
TZ=Asia/Seoul

# [Optional] Server port (default: 3001)
# MT_SERVER_PORT=3001

# [Optional] Admin account initialization on startup
# If set, creates the account on first run or resets the password on subsequent runs
# MT_ADMIN_USERNAME=admin
# MT_ADMIN_PASSWORD=your-password
