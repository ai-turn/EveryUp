# EveryUp — Docker Compose Environment Variables
# Copy to .env and adjust values:
#   cp .env.example .env
#
# Then start:
#   docker compose up -d

# -----------------------------------------------------------------
# Server
# -----------------------------------------------------------------

# Run mode: development | production
# production enforces: no wildcard CORS, strong admin password (≥8 chars)
EVERYUP_SERVER_MODE=production

# Port exposed on the host (default: 3001)
# EVERYUP_SERVER_PORT=3001

# Allowed CORS origins — required when frontend is on a different origin
# (e.g., Nginx reverse proxy, CDN, or separate frontend container)
# EVERYUP_SERVER_ALLOWORIGINS=https://your-domain.com

# -----------------------------------------------------------------
# Admin account (first run / password reset)
# -----------------------------------------------------------------

# Creates or resets the admin login account on startup.
# Leave commented out to create your account via the browser on first launch.
# Uncomment to pre-seed credentials or to reset a forgotten password.
# EVERYUP_ADMIN_USERNAME=admin
# EVERYUP_ADMIN_PASSWORD=changeme-use-strong-password

# -----------------------------------------------------------------
# Database (optional overrides)
# -----------------------------------------------------------------

# SQLite file path inside container (volume is mounted at /app/data)
# EVERYUP_DATABASE_PATH=./data/monitoring.db

# -----------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------
TZ=Asia/Seoul
